# API Configuration
# Production (school Raspberry Pi):     https://likha.local  or  https://192.168.1.1
# Android Emulator (dev):               https://10.0.2.2  (DEV_MODE=true skips cert check)
# iOS Simulator (dev):                  https://localhost  (DEV_MODE=true skips cert check)
# Physical device on same WiFi (dev):   https://192.168.x.x
API_BASE_URL=https://10.0.2.2

# Logging (set to false to reduce console noise)
PROVIDER_LOGGING_ENABLED=false
REPO_LOGGING_ENABLED=false
CACHE_LOGGING_ENABLED=false
CORE_LOGGING_ENABLED=false
PAGE_LOGGING_ENABLED=false
SERVICE_LOGGING_ENABLED=false
STATS_LOGGING_ENABLED=false
VALIDATION_LOGGING_ENABLED=false
SYNC_LOGGING_ENABLED=true
SF9_LOGGING_ENABLED=true

# Development Mode
# true  — disables cert validation (self-signed allowed) and shows debug snackbars
# false — requires school CA installed on device; use for production builds
DEV_MODE=true
