{
  "name": "likha-load-tests",
  "version": "1.0.0",
  "private": true,
  "description": "k6 load tests for Likha LMS server",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "node build.mjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test:baseline": "k6 run --env-file .env dist/baseline.js",
    "test:stress": "k6 run --env-file .env dist/stress.js",
    "test:classroom": "k6 run --env-file .env dist/classroom-mix.js",
    "test:exam": "k6 run --env-file .env dist/exam-surge.js",
    "test:delta": "k6 run --env-file .env dist/delta-sync.js",
    "test:grading": "k6 run --env-file .env dist/teacher-grading.js",
    "test:all": "pnpm build && k6 run --env-file .env dist/baseline.js && k6 run --env-file .env dist/stress.js"
  },
  "devDependencies": {
    "@types/k6": "^0.54.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0"
  }
}
