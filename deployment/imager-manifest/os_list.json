{
  "os_list": [
    {
      "name": "Likha Classroom Server",
      "description": "Self-contained classroom server with mesh replication for Raspberry Pi 4/5",
      "icon": "https://likha.app/imager/icon.png",
      "url": "https://github.com/sibato/likha/releases/latest/download/likha-server-latest.img.xz",
      "extract_size": 3221225472,
      "image_download_size": 0,
      "release_date": "2024-01-01",
      "init_format": "systemd",
      "devices": [
        "pi4",
        "pi5"
      ],
      "format": "custom",
      "customization": {
        "schema": {
          "mesh_group_id": {
            "type": "string",
            "minLength": 3,
            "maxLength": 32,
            "description": "School Code / Mesh Group ID (shared by all nodes in the classroom)"
          },
          "wifi_ssid": {
            "type": "string",
            "maxLength": 64,
            "description": "Optional WiFi SSID (if not using Ethernet router mode)"
          },
          "wifi_password": {
            "type": "string",
            "maxLength": 64,
            "description": "Optional WiFi password"
          },
          "wifi_country": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "description": "ISO 3166-1 alpha-2 country code for WiFi (e.g., PH, US)"
          },
          "school_code": {
            "type": "string",
            "maxLength": 32,
            "description": "School identifier (e.g., ESATQL)"
          }
        }
      }
    }
  ]
}
