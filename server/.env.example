DATABASE_URL=sqlite://./data/lms.db?mode=rwc

HOST=0.0.0.0
PORT=8080

JWT_SECRET=dev-secret-key-please-change-min-32-chars-for-production-use
JWT_ACCESS_TOKEN_EXPIRATION=86400
JWT_REFRESH_TOKEN_EXPIRATION=604800

# Database encryption key for SQLCipher (whole-database encryption at rest).
# Generate a strong key, e.g.:
#   openssl rand -base64 32
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DB_ENCRYPTION_KEY=change-me-to-a-strong-random-key-min-32-chars

# Storage Paths
MATERIALS_PATH=./storage/materials
SUBMISSIONS_PATH=./storage/submissions
EXPORTS_PATH=./storage/exports

# School Setup
SCHOOL_CODE=ESATQL

# CORS — comma-separated list of allowed origins (browser clients).
# Mobile native apps bypass CORS; this protects the web dashboard.
# Leave empty to deny all cross-origin requests.
ALLOWED_ORIGINS=https://likha.local,https://192.168.1.1

# Maximum allowed request body size in megabytes (default: 55).
# Should be slightly above the largest file upload the app allows (50 MB).
MAX_BODY_SIZE_MB=55

# Logging
RUST_LOG=info,server=debug